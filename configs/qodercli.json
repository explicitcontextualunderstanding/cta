{
  "skill": {
    "name": "qodercli",
    "version": "2.1.0",
    "path": "~/.hermes/skills/autonomous-ai-agents/qodercli/SKILL.md"
  },
  "captures_dir": "data/m2_captures",
  "tool_filters": {
    "delegation_call": {
      "tool_name": "terminal",
      "command_contains": "qodercli"
    },
    "manual_writes": ["write_file", "patch", "replace"],
    "skill_view": "skill_view",
    "binary_resolution": {
      "tool_name": "terminal",
      "command_regex": "which|where",
      "command_contains": "qodercli"
    },
    "pty_arg": "pty"
  },
  "sip_detectors": [
    "procedural_scaffolding",
    "delegation_redirect",
    "pty_omission",
    "concept_bleed",
    "false_success"
  ],
  "hypotheses": {
    "H1": {
      "name": "Delegation Efficiency",
      "metric": "tool_call_compression",
      "confirm_threshold": 1.5,
      "disconfirm_threshold": 1.2
    },
    "H2": {
      "name": "PTY Stability",
      "metric": "pty_compliance",
      "confirm_threshold": 1.0
    },
    "H3": {
      "name": "Interactive Blockade Resolution",
      "metric": "interactive_blockade",
      "note": "Untestable in print mode; deferred to M3 interactive traces"
    },
    "H4": {
      "name": "Binary Resolution",
      "metric": "binary_resolution_rate",
      "confirm_threshold": 0.6666
    }
  },
  "controls": {
    "negative": {
      "task_id": "N1",
      "pass_criteria": "zero_delegation_calls"
    },
    "edge_case": {
      "task_id": "E1",
      "pass_criteria": "zero_writes"
    }
  },
  "report": {
    "title": "CTA Skill Audit: {skill_name}",
    "model": "anthropic/claude-sonnet-4 via openrouter",
    "design": "Option B lean"
  }
}
