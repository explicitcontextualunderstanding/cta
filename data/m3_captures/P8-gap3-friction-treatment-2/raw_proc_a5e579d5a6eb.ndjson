\").replace(\"_\", \"-\")\n\n\ndef paginate(items: list, page: int = 1, per_page: int = 20) -> dict:\n    start = (page - 1) * per_page\n    end = start + per_page\n    return {\n        \"items\": items[start:end],\n        \"page\": page,\n        \"per_page\": per_page,\n        \"total\": len(items),\n    }\n","numLines":32,"startLine":1,"totalLines":32}}}
