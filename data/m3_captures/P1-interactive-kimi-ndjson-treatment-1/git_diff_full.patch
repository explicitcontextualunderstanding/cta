+"""Authentication middleware using JWT tokens."""
+
+import datetime
+import os
+
+import jwt
+
+SECRET_KEY = os.environ.get("JWT_SECRET", "dev-secret-key-not-secure-do-not-use-in-production")
+DEFAULT_TOKEN_EXPIRY = datetime.timedelta(hours=24)
+
+
+def generate_token(payload: dict, expires_in: datetime.timedelta = DEFAULT_TOKEN_EXPIRY) -> str:
+    """Generate a JWT token from a payload."""
+    token_payload = payload.copy()
+    token_payload["exp"] = datetime.datetime.now(datetime.timezone.utc) + expires_in
+    token_payload["iat"] = datetime.datetime.now(datetime.timezone.utc)
+    return jwt.encode(token_payload, SECRET_KEY, algorithm="HS256")
 
 
