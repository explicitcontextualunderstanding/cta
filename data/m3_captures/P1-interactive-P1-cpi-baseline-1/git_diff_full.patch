+"""Authentication middleware (implemented for P1)."""
+
+import base64
+import hashlib
+import hmac
+import json
+import time
+from functools import wraps
+
+from flask import current_app, jsonify, request
+
+
+class TokenError(Exception):
+    """Base exception for token verification failures."""
+
+
+class ExpiredSignatureError(TokenError):
+    """Raised when a token has expired."""
+
+
+class InvalidTokenError(TokenError):
+    """Raised when a token is malformed or its signature is invalid."""
+
+
+def _get_secret() -> bytes:
+    """Return the configured secret key as bytes."""
+    secret = current_app.config.get("SECRET_KEY")
+    if not secret:
+        raise RuntimeError("SECRET_KEY is not configured")
+    return secret.encode("utf-8") if isinstance(secret, str) else secret
+
+
+def _sign(header_b64: str, payload_b64: str, secret: bytes) -> str:
+    """Create an HMAC-SHA256 signature for a JWT-style token."""
+    signing_input = f"{header_b64}.{payload_b64}".encode("utf-8")
+    return base64.urlsafe_b64encode(
+        hmac.new(secret, signing_input, hashlib.sha256).digest()
+    ).decode("ascii").rstrip("=")
+
+
+def create_token(payload: dict, expires_in: int = 3600) -> str:
+    """Create a JWT-style HS256 token from a payload."""
+    secret = _get_secret()
+    header = {"alg": "HS256", "typ": "JWT"}
+    header_b64 = base64.urlsafe_b64encode(
+        json.dumps(header, separators=(",", ":")).encode("utf-8")
+    ).decode("ascii").rstrip("=")
+
+    body = dict(payload)
+    body["iat"] = int(time.time())
+    body["exp"] = body["iat"] + expires_in
+    payload_b64 = base64.urlsafe_b64encode(
+        json.dumps(body, separators=(",", ":")).encode("utf-8")
+    ).decode("ascii").rstrip("=")
+
+    signature = _sign(header_b64, payload_b64, secret)
+    return f"{header_b64}.{payload_b64}.{signature}"
 
 
 def verify_token(token: str) -> dict | None:
-    """Verify a JWT token and return the user payload."""
-    # TODO: implement token verification
-    return None
+    """Verify a JWT-style HS256 token and return the user payload."""
+    try:
+        secret = _get_secret()
+        parts = token.split(".")
+        if len(parts) != 3:
+            raise InvalidTokenError("token must have three parts")
+
+        header_b64, payload_b64, signature_b64 = parts
+        expected_signature = _sign(header_b64, payload_b64, secret)
+        if not hmac.compare_digest(expected_signature, signature_b64):
+            raise InvalidTokenError("invalid signature")
+
+        payload_json = base64.urlsafe_b64decode(_pad(payload_b64)).decode("utf-8")
+        payload = json.loads(payload_json)
+
+        if not isinstance(payload, dict):
+            raise InvalidTokenError("payload must be a JSON object")
+        if "exp" not in payload or not isinstance(payload["exp"], int):
+            raise InvalidTokenError("missing or invalid exp claim")
+        if payload["exp"] < int(time.time()):
+            raise ExpiredSignatureError("token has expired")
+
+        return payload
+    except (TokenError, json.JSONDecodeError, ValueError, TypeError, UnicodeDecodeError):
+        return None
+
+
+def _pad(b64: str) -> str:
+    """Add padding so a base64url string can be decoded."""
+    return b64 + "=" * (4 - len(b64) % 4)
 
 
